{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sift",
  "version": "0.1.0",
  "identifier": "com.chocolatez.sift",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8327",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Sift",
        "width": 1280,
        "height": 800,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "backgroundColor": "#0E0E14"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: http:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
