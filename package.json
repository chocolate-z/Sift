{
  "name": "sift",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "description": "Sift — desktop universal data collection tool (monorepo root)",
  "scripts": {
    "dev": "pnpm --filter @sift/app dev",
    "build": "pnpm --filter @sift/app build",
    "preview": "pnpm --filter @sift/app preview",
    "tauri:dev": "pnpm --filter @sift/app tauri:dev",
    "tauri:build": "pnpm --filter @sift/app tauri:build",
    "engine:test": "cargo test --manifest-path packages/app/src-tauri/Cargo.toml -p sift-engine",
    "engine:check": "cargo check --manifest-path packages/app/src-tauri/Cargo.toml -p sift-engine",
    "engine:clippy": "cargo clippy --manifest-path packages/app/src-tauri/Cargo.toml -p sift-engine --all-targets -- -D warnings",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.9"
  }
}
